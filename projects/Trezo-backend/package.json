{
  "name": "trezo-backend",
  "version": "1.0.0",
  "description": "Trezo Backend Services - Algorand blockchain services and APIs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:properties": "jest --testPathPattern=invoiceProperties --no-coverage",
    "lint": "eslint src/**/*.ts",
    "setup": "node setup-treasury.js",
    "init-db": "ts-node src/scripts/initDatabase.ts",
    "migrate-phase2": "ts-node src/scripts/migratePhase2.ts",
    "migrate-smart-invoice": "ts-node src/scripts/migrateSmartInvoice.ts",
    "migrate-phase3-phase4": "ts-node src/scripts/migratePhase3Phase4.ts",
    "migrate-chat": "ts-node src/scripts/migrateChat.ts",
    "postinstall": "npm run build"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/src/tests/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    }
  },
  "keywords": [
    "algorand",
    "blockchain",
    "api",
    "wallet",
    "trezo"
  ],
  "author": "SrikarnivasLexfintech <dev@lexfintech.io>",
  "license": "MIT",
  "dependencies": {
    "@algorandfoundation/algokit-utils": "^9.0.0",
    "@aws-sdk/client-kms": "^3.1009.0",
    "@types/multer": "^2.1.0",
    "@types/pg": "^8.18.0",
    "algosdk": "^3.0.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "openai": "^6.29.0",
    "pg": "^8.20.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "eslint": "^8.54.0",
    "fast-check": "^4.6.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": "20.x",
    "npm": ">=9.0.0"
  }
}
